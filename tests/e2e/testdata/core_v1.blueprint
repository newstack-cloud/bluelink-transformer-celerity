version "2025-11-02"

transform "celerity-2026-02-27-draft"

variable namePrefix: string {}

resource nightlySync: celerity/schedule {
    select by label {
        worker = "sync"
    }
    spec {
        schedule = "rate(1 hour)"
    }
}

resource syncHandler: celerity/handler {
    metadata {
        labels = { worker = "sync" }
        annotations = {
            "celerity.handler.schedule" = true
        }
    }
    select by label {
        store = "appConfig"
    }
    spec {
        handlerName = "${variables.namePrefix}-lifecycle"
        handler = "handlers.sync"
        runtime = "nodejs24.x"
        environmentVariables = {
            SYNC_MODE = "incremental"
        }
    }
}

resource appConfig: celerity/config {
    metadata {
        labels = { store = "appConfig" }
    }
    spec {
        name = "lifecycleconfig"
        values = {
            logLevel = "info"
        }
        plaintext = ["logLevel"]
    }
}
