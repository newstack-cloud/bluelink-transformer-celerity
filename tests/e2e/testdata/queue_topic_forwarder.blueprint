version "2025-11-02"

transform "celerity-2026-02-27-draft"

variable namePrefix: string {}

resource sourceQueue: celerity/queue {
    select by label {
        topic = "events"
    }
    spec {
        name = "${variables.namePrefix}-source"
        visibilityTimeout = 120
    }
}

resource eventsTopic: celerity/topic {
    metadata {
        labels = { topic = "events" }
    }
    spec {
        name = "${variables.namePrefix}-events"
    }
}

export sourceQueueArn: string {
    field = resources.sourceQueue.spec.id
}

export eventsTopicArn: string {
    field = resources.eventsTopic.spec.id
}
