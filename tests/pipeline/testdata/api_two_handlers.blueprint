version "2025-11-02"

transform "celerity-2026-02-27-draft"

resource ordersApi: celerity/api {
    select by label {
        app = "orders"
    }
    spec {
        protocols = ["http"]
    }
}

resource listOrders: celerity/handler {
    metadata {
        labels = { app = "orders" }
        annotations = {
            "celerity.handler.http" = true,
            "celerity.handler.http.method" = "GET",
            "celerity.handler.http.path" = "/orders"
        }
    }
    spec {
        handlerName = "listOrders"
        handler = "handlers.list"
        runtime = "nodejs24.x"
    }
}

resource createOrder: celerity/handler {
    metadata {
        labels = { app = "orders" }
        annotations = {
            "celerity.handler.http" = true,
            "celerity.handler.http.method" = "POST",
            "celerity.handler.http.path" = "/orders"
        }
    }
    spec {
        handlerName = "createOrder"
        handler = "handlers.create"
        runtime = "nodejs24.x"
    }
}
