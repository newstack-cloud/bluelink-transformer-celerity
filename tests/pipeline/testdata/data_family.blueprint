version "2025-11-02"

transform "celerity-2026-02-27-draft"

resource appNetwork: celerity/vpc {
    select by label {
        network = "main"
    }
    spec {
        name = "app-net"
        preset = "standard"
    }
}

resource sessionsCache: celerity/cache {
    metadata {
        labels = { network = "main", data = "orders" }
    }
    spec {
        name = "sessions"
        authMode = "iam"
    }
}

resource ordersDb: celerity/sqlDatabase {
    metadata {
        labels = { network = "main", data = "orders" }
    }
    spec {
        name = "orders"
        engine = "postgres"
    }
}

resource dataHandler: celerity/handler {
    metadata {
        labels = { network = "main" }
    }
    select by label {
        data = "orders"
    }
    spec {
        handlerName = "dataHandler"
        handler = "handlers.data"
        runtime = "nodejs24.x"
    }
}
