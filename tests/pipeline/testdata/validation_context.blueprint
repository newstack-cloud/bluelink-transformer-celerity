version "2025-11-02"

transform "celerity-2026-02-27-draft"

resource valApi: celerity/api {
    select by label {
        app = "validation"
    }
    spec {
        protocols = ["http"]
    }
}

resource valHandler: celerity/handler {
    metadata {
        labels = { app = "validation", network = "val" }
        annotations = {
            "celerity.handler.http" = true,
            "celerity.handler.http.method" = "GET",
            "celerity.handler.http.path" = "/validate"
        }
    }
    spec {
        handlerName = "valHandler"
        handler = "handlers.validate"
        runtime = "nodejs24.x"
    }
}

resource valSettings: celerity/config {
    metadata {
        labels = { app = "validation" }
    }
    spec {
        name = "valSettings"
        values = { apiKey = "abc123" }
    }
}

resource valNetwork: celerity/vpc {
    select by label {
        network = "val"
    }
    spec {
        name = "val-net"
    }
}
