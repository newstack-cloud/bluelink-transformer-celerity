{
  "version": "1",
  "runtime": "nodejs24.x",
  "target": "aws-serverless",
  "handlers": {},
  "lambda": {
    "appCode": {
      "type": "zip",
      "s3Bucket": "pipeline-test-artifacts",
      "s3Key": "app.zip",
      "size": 1024,
      "contentHash": "pipelineAppHash"
    },
    "entryPoint": "__celerity_lambda_entry__.handler",
    "sharedLayer": {
      "type": "zip",
      "s3Bucket": "pipeline-test-artifacts",
      "s3Key": "shared-layer.zip",
      "size": 2048,
      "contentHash": "pipelineLayerHash"
    }
  }
}
