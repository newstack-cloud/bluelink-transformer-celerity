version "2025-11-02"

transform "celerity-2026-02-27-draft"

resource submitOrder: celerity/handler {
    select by label {
        queue = "orders"
        storage = "orders"
    }
    spec {
        handlerName = "submitOrder"
        handler = "handlers.submit"
        runtime = "nodejs24.x"
    }
}

resource orderUploads: celerity/bucket {
    metadata {
        labels = { storage = "orders" }
    }
    spec {}
}

resource ordersQueue: celerity/queue {
    metadata {
        labels = { queue = "orders" }
    }
    select by label {
        consumer = "orders"
    }
    spec {
        name = "orders"
    }
}

resource ordersConsumer: celerity/consumer {
    metadata {
        labels = { consumer = "orders" }
    }
    select by label {
        worker = "orders"
    }
    spec {
        batchSize = 5
    }
}

resource processOrder: celerity/handler {
    metadata {
        labels = { worker = "orders" }
        annotations = {
            "celerity.handler.consumer" = true
        }
    }
    spec {
        handlerName = "processOrder"
        handler = "handlers.process"
        runtime = "nodejs24.x"
    }
}
