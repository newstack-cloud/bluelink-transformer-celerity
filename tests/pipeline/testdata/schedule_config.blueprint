version "2025-11-02"

transform "celerity-2026-02-27-draft"

resource nightlySync: celerity/schedule {
    select by label {
        worker = "sync"
    }
    spec {
        schedule = "rate(1 hour)"
    }
}

resource syncWorker: celerity/handler {
    metadata {
        labels = { worker = "sync" }
        annotations = {
            "celerity.handler.schedule" = true
        }
    }
    select by label {
        store = "appConfig"
    }
    spec {
        handlerName = "syncWorker"
        handler = "handlers.sync"
        runtime = "nodejs24.x"
        environmentVariables = {
            CELERITY_CONFIG_APP_STORE_ID = resources.appConfig.spec.id
        }
    }
}

resource appConfig: celerity/config {
    metadata {
        labels = { store = "appConfig" }
    }
    spec {
        name = "appConfig"
        values = {
            logLevel = "info",
            dbPassword = "s3cr3t"
        }
        plaintext = ["logLevel"]
    }
}
