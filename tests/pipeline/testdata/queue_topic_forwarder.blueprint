version "2025-11-02"

transform "celerity-2026-02-27-draft"

resource inboundQueue: celerity/queue {
    select by label {
        topic = "events"
    }
    spec {
        name = "inbound"
    }
}

resource eventsTopic: celerity/topic {
    metadata {
        labels = { topic = "events" }
    }
    spec {
        name = "events"
    }
}
