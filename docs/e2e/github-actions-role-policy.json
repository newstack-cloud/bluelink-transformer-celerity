{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "CloudControlCRUD",
      "Effect": "Allow",
      "Action": [
        "cloudformation:CreateResource",
        "cloudformation:GetResource",
        "cloudformation:UpdateResource",
        "cloudformation:DeleteResource",
        "cloudformation:ListResources",
        "cloudformation:GetResourceRequestStatus",
        "cloudformation:ListResourceRequests",
        "cloudformation:CancelResourceRequest"
      ],
      "Resource": "*"
    },
    {
      "Sid": "LeakSweepAndUnscopableReads",
      "Effect": "Allow",
      "Action": [
        "lambda:ListFunctions",
        "lambda:ListEventSourceMappings",
        "iam:ListRoles",
        "iam:ListPolicies",
        "sqs:ListQueues",
        "sns:ListTopics",
        "dynamodb:ListTables",
        "s3:ListAllMyBuckets",
        "events:ListRules",
        "ssm:DescribeParameters",
        "secretsmanager:ListSecrets",
        "secretsmanager:GetRandomPassword"
      ],
      "Resource": "*"
    },
    {
      "Sid": "LambdaFunctionsAppScoped",
      "Effect": "Allow",
      "Action": "lambda:*",
      "Resource": "arn:aws:lambda:*:*:function:celerity-e2e-*"
    },
    {
      "Sid": "LambdaLayers",
      "Effect": "Allow",
      "Action": [
        "lambda:PublishLayerVersion",
        "lambda:GetLayerVersion",
        "lambda:DeleteLayerVersion",
        "lambda:ListLayerVersions"
      ],
      "Resource": "arn:aws:lambda:*:*:layer:*"
    },
    {
      "Sid": "LambdaEventSourceMappings",
      "Effect": "Allow",
      "Action": [
        "lambda:CreateEventSourceMapping",
        "lambda:GetEventSourceMapping",
        "lambda:UpdateEventSourceMapping",
        "lambda:DeleteEventSourceMapping"
      ],
      "Resource": "*",
      "Condition": {
        "ArnLikeIfExists": {
          "lambda:FunctionArn": "arn:aws:lambda:*:*:function:celerity-e2e-*"
        }
      }
    },
    {
      "Sid": "IAMRolesAppScoped",
      "Effect": "Allow",
      "Action": [
        "iam:CreateRole",
        "iam:DeleteRole",
        "iam:GetRole",
        "iam:UpdateRole",
        "iam:UpdateAssumeRolePolicy",
        "iam:TagRole",
        "iam:UntagRole",
        "iam:PutRolePolicy",
        "iam:DeleteRolePolicy",
        "iam:GetRolePolicy",
        "iam:ListRolePolicies",
        "iam:ListAttachedRolePolicies",
        "iam:AttachRolePolicy",
        "iam:DetachRolePolicy"
      ],
      "Resource": "arn:aws:iam::*:role/celerity-e2e-*"
    },
    {
      "Sid": "IAMPassRoleToServices",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": "arn:aws:iam::*:role/celerity-e2e-*",
      "Condition": {
        "StringEquals": {
          "iam:PassedToService": [
            "lambda.amazonaws.com",
            "events.amazonaws.com",
            "rds.amazonaws.com"
          ]
        }
      }
    },
    {
      "Sid": "IAMBluelinkManagedOverflowPolicies",
      "Effect": "Allow",
      "Action": [
        "iam:CreatePolicy",
        "iam:DeletePolicy",
        "iam:GetPolicy",
        "iam:CreatePolicyVersion",
        "iam:DeletePolicyVersion",
        "iam:ListPolicyVersions"
      ],
      "Resource": "arn:aws:iam::*:policy/bluelink-link-access-*"
    },
    {
      "Sid": "S3AppScoped",
      "Effect": "Allow",
      "Action": "s3:*",
      "Resource": "arn:aws:s3:::celerity-e2e-*"
    },
    {
      "Sid": "SQSAppScoped",
      "Effect": "Allow",
      "Action": "sqs:*",
      "Resource": "arn:aws:sqs:*:*:celerity-e2e-*"
    },
    {
      "Sid": "SNSAppScoped",
      "Effect": "Allow",
      "Action": "sns:*",
      "Resource": "arn:aws:sns:*:*:celerity-e2e-*"
    },
    {
      "Sid": "DynamoDBAppScoped",
      "Effect": "Allow",
      "Action": "dynamodb:*",
      "Resource": "arn:aws:dynamodb:*:*:table/celerity-e2e-*"
    },
    {
      "Sid": "ApiGatewayV2",
      "Effect": "Allow",
      "Action": [
        "apigateway:GET",
        "apigateway:POST",
        "apigateway:PUT",
        "apigateway:PATCH",
        "apigateway:DELETE"
      ],
      "Resource": [
        "arn:aws:apigateway:*::/apis",
        "arn:aws:apigateway:*::/apis/*",
        "arn:aws:apigateway:*::/tags/*"
      ]
    },
    {
      "Sid": "EventBridgeAppScoped",
      "Effect": "Allow",
      "Action": "events:*",
      "Resource": "arn:aws:events:*:*:rule/celerity-e2e-*"
    },
    {
      "Sid": "SSMCelerityTree",
      "Effect": "Allow",
      "Action": [
        "ssm:PutParameter",
        "ssm:DeleteParameter",
        "ssm:DeleteParameters",
        "ssm:GetParameter",
        "ssm:GetParameters",
        "ssm:GetParametersByPath",
        "ssm:AddTagsToResource",
        "ssm:RemoveTagsFromResource",
        "ssm:ListTagsForResource"
      ],
      "Resource": [
        "arn:aws:ssm:*:*:parameter/celerity",
        "arn:aws:ssm:*:*:parameter/celerity/*"
      ]
    },
    {
      "Sid": "SecretsManagerCelerityScoped",
      "Effect": "Allow",
      "Action": "secretsmanager:*",
      "Resource": [
        "arn:aws:secretsmanager:*:*:secret:/celerity/*",
        "arn:aws:secretsmanager:*:*:secret:celerity-e2e-*"
      ]
    }
  ]
}
