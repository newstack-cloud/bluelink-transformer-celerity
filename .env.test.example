# Environment for real provider e2e tests (scripts/run-tests.sh --e2e).
# Copy to .env.test and populate the env vars, .env.test is gitignored and must stay so.
# Both values are required, without AWS_REGION every e2e test skips and the
# run falsely looks green (the script now errors on a missing region).
AWS_PROFILE=your-automated-test-profile
AWS_REGION=eu-west-2
